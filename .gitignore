# =============================================================================
Knowledge/聚宽回测数据/
Knowledge/zxz_399101_pit_membership_tuesdays.csv
Knowledge/**/*.parquet
Knowledge/**/*.csv
Knowledge/**/*.xlsx
Knowledge/**/*.pkl
# Factor-expansion GPT 5.5 Pro review CSVs — tracked so the handoff artifact set is
# complete in-repo (referenced by the factor_expansion proposal + README).
!Knowledge/factor_expansion_gpt_review_new_candidates.csv
!Knowledge/factor_candidates_round3_additions_corrections.csv

