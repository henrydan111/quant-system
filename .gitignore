# =============================================================================
# Virtual environments
# =============================================================================
venv/
.venv/
env/

# =============================================================================
# Secrets
# =============================================================================
.env
*.token
*.pem
*.key

# =============================================================================
# Python build / cache artifacts
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
build/
dist/
.eggs/

# =============================================================================
# data/ — raw and derived datasets
# The repo documents the data system but does NOT ship the data itself.
# The whitelist below preserves curated documentation files.
# =============================================================================
data/*
!data/README.md
!data/data_dictionary.md
!data/data_tracker.md

# Keep registry directories so READMEs survive, but exclude all data files
!data/factor_registry/
data/factor_registry/*
!data/factor_registry/README.md

!data/candidate_registry/
data/candidate_registry/*
!data/candidate_registry/README.md

!data/signal_registry/
data/signal_registry/*
!data/signal_registry/README.md

!data/model_registry/
data/model_registry/*
!data/model_registry/README.md

!data/strategy_registry/
data/strategy_registry/*
!data/strategy_registry/README.md

# External JoinQuant PIT cache — keep README only
!data/external/
data/external/*
!data/external/jq_pit_cache/
data/external/jq_pit_cache/*
!data/external/jq_pit_cache/README.md

# Qlib provider — keep instruments README only (universe-sidecar docs)
!data/qlib_data/
data/qlib_data/*
!data/qlib_data/instruments/
data/qlib_data/instruments/*
!data/qlib_data/instruments/README.md

# Factor-research field inventory — a committed, human-readable snapshot of the
# materialized Qlib field universe so the repo tracks the data fields the system
# exposes (regenerated by workspace/scripts/generate_factor_candidates.py).
!data/factor_research/
data/factor_research/*
!data/factor_research/*.md

# Block all registry backup snapshots
data/*.bak_*/
data/*_backup*/

# =============================================================================
# MLflow / experiment tracking
# =============================================================================
mlruns/
workspace/mlruns/
.mlflow/

# =============================================================================
# Logs
# =============================================================================
logs/
*.log
*.log.*

# =============================================================================
# workspace/ — research scratch space
# Keep structure + scripts + notebooks + configs; exclude run artifacts.
# =============================================================================
workspace/outputs/
# Local-only PIT-lookahead legacy sandbox archive: the 73 invalidated
# build_pit_pivot scripts are kept untracked (the README.md manifest stays
# tracked). Prevents an accidental `git add` from reintroducing the dead lineage.
workspace/scripts/archive/pit_lookahead_legacy_2026_05/*.py
workspace/research/**/outputs/
workspace/research/**/cache/
workspace/research/**/runs/
workspace/research/**/steps/
workspace/research/**/dag_plan.json
workspace/research/**/dag_state.json
workspace/research/**/run_metadata.json
workspace/research/**/artifact_manifest.json
workspace/research/**/produced_objects.json
workspace/research/**/review_summary.json
workspace/research/**/eligible_map.json
workspace/research/**/console.log
workspace/research/**/run_console.log
workspace/research/**/*.parquet
workspace/research/**/*.csv
workspace/research/**/*.html
workspace/research/**/*.pkl
workspace/research/**/*.png
workspace/research/**/*.jpg
workspace/research/**/*.pdf
workspace/research/**/.ipynb_checkpoints/
# Factor-expansion handoff: track the machine-readable candidate lists next to the
# proposal markdown so the GPT review has the full artifact set in-repo.
!workspace/research/factor_expansion/*.csv
# Audit + IS-screening artifacts (read-only evidence, no compute side-effects):
!workspace/research/factor_expansion/screening_is/
!workspace/research/factor_expansion/screening_is/*.csv
!workspace/research/factor_expansion/screening_is/*.parquet
!workspace/research/factor_expansion/screening_is_47/
!workspace/research/factor_expansion/screening_is_47/*.csv
!workspace/research/factor_expansion/screening_is_47/*.parquet

