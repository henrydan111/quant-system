# =============================================================================
# Environment variables for 量化系统
# =============================================================================
# Copy this file to .env (in the project root) and fill in real values.
# .env is gitignored — never commit real tokens.
#
# config.yaml references variables here via ${VAR_NAME} substitution.
# =============================================================================

# Tushare Pro API token — required for any data ingestion or refresh pipeline.
# Get one from https://tushare.pro/ (subscription required for VIP endpoints).
# Leave blank for read-only inspection (tests that don't need live data still run).
TUSHARE_TOKEN=

# Optional: override the MLflow tracking URI. By default config.yaml uses a
# local mlruns/ directory. Set this to a remote tracking server if you have one.
# MLFLOW_TRACKING_URI=

# Optional: override the Qlib provider URI. By default config.yaml points at
# data/qlib_data. Override only if you stage providers elsewhere.
# QLIB_PROVIDER_URI=
